# Production site URL (used in build outputs; optional override)
# VITE_SITE_ORIGIN=https://styledesigner.co.in

# App Store listing URLs — set in Netlify/host env for production (avoids App Store / Play search fallbacks)
# VITE_APP_STORE_IOS_URL=https://apps.apple.com/in/app/style-ai/idYOUR_APP_ID
# VITE_APP_STORE_ANDROID_URL=https://play.google.com/store/apps/details?id=YOUR_PACKAGE&hl=en&gl=in

# Google Search Console HTML tag verification (injected at build time into <head>)
# VITE_GOOGLE_SITE_VERIFICATION=paste_token_from_search_console

# Google Analytics 4 — leave empty to disable; when set, loads only after “Accept analytics” on the homepage
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
